<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | escape }}</title>
    <meta name="description" content="{{ description | escape }}">
    <meta property="og:title" content="{{ title | escape }}">
    <meta property="og:description" content="{{ description | escape }}">
    <meta name="theme-color" content="#06080d">
    <link rel="preload" href="/fonts/Inter-3.19.var.woff2" as="font" type="font/woff2" crossorigin>
    <style>
      @font-face {
        font-family: Inter;
        src: url('/fonts/Inter-3.19.var.woff2') format('woff2');
        font-weight: 100 900;
        font-display: swap;
      }
      :root {
        --bg: #05070b;
        --panel: #090d13;
        --panel-2: #0d121b;
        --ink: #f4f7fb;
        --muted: #8d98aa;
        --faint: #586273;
        --line: #202838;
        --blue: #53a8ff;
        --amber: #f7b500;
        --violet: #9b6cff;
        --green: #18d6a3;
        --red: #ff5d5d;
        --radius: 10px;
        color-scheme: dark;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background:
          radial-gradient(circle at 50% -12%, rgba(83,168,255,.14), transparent 34rem),
          linear-gradient(180deg, #07090f 0%, var(--bg) 42rem);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.55;
      }
      a { color: inherit; text-decoration: none; }
      .wrap { width: min(1040px, calc(100% - 40px)); margin: 0 auto; }
      .topbar {
        position: sticky; top: 0; z-index: 10;
        backdrop-filter: blur(18px);
        background: rgba(5, 7, 11, .74);
        border-bottom: 1px solid rgba(255,255,255,.06);
      }
      .nav { display:flex; align-items:center; justify-content:space-between; min-height:64px; gap:20px; }
      .brand { display:flex; align-items:center; gap:12px; font-weight:760; letter-spacing:-.03em; }
      .mark { display:grid; place-items:center; width:34px; height:34px; border:1px solid var(--line); border-radius:9px; color:var(--green); background:#07120f; font-weight:820; }
      .navlinks { display:flex; gap:18px; color:var(--muted); font-size:14px; }
      .navlinks a:hover { color:var(--ink); }
      .hero { padding:72px 0 36px; }
      .identity { display:flex; align-items:center; gap:24px; margin-bottom:42px; }
      .portrait { width:86px; height:86px; border-radius:50%; object-fit:cover; border:1px solid rgba(255,255,255,.1); filter:saturate(.9); }
      .identity h1 { margin:0; font-size:clamp(34px, 5vw, 54px); line-height:.96; letter-spacing:-.065em; }
      .subtitle { margin:8px 0 0; color:var(--muted); font-size:16px; }
      .hero-copy { max-width: 820px; }
      .eyebrow { margin:0 0 12px; color:var(--blue); text-transform:uppercase; letter-spacing:.18em; font:700 12px/1 Inter, sans-serif; }
      .hero h2 { margin:0; font-size:clamp(34px, 6.2vw, 72px); line-height:.93; letter-spacing:-.075em; text-wrap:balance; }
      .hero h2 strong { color:var(--amber); font-weight:820; }
      .lede { max-width:780px; margin:22px 0 0; color:#b5bdcb; font-size:clamp(18px, 2vw, 22px); }
      .metric-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:18px; margin:34px 0 40px; }
      .metric { border:1px solid var(--line); border-radius:var(--radius); background:rgba(255,255,255,.025); padding:20px; text-align:center; }
      .metric b { display:block; font-size:26px; letter-spacing:-.04em; }
      .metric span { display:block; margin-top:4px; color:var(--muted); font-size:14px; line-height:1.25; }
      .split { display:grid; grid-template-columns:1fr 1fr; gap:44px; border-block:1px solid rgba(255,255,255,.08); padding:34px 0; }
      .label { margin:0 0 14px; text-transform:uppercase; letter-spacing:.22em; color:var(--faint); font:650 12px/1 Inter, sans-serif; }
      .chain, .roles { display:flex; flex-wrap:wrap; gap:9px; align-items:center; color:var(--muted); }
      .chain a, .roles span { font-weight:650; }
      .blue { color:var(--blue); } .amber { color:var(--amber); } .violet { color:var(--violet); } .green { color:var(--green); } .red { color:var(--red); }
      .small { margin:14px 0 0; color:var(--muted); font-size:15px; max-width:420px; }
      .cta { padding:36px 0 42px; }
      .cta h3 { font-size:24px; letter-spacing:-.03em; margin:0 0 8px; }
      .cta p { color:#b8c0cd; margin:0 0 18px; max-width:820px; }
      .buttons { display:flex; gap:12px; flex-wrap:wrap; }
      .button { border:1px solid var(--line); background:rgba(255,255,255,.035); border-radius:9px; padding:10px 16px; color:#dce4ef; font-weight:600; }
      .button.primary { background:#eef3ff; color:#05070b; border-color:#eef3ff; }
      .quote { margin:28px 0 64px; border:1px solid var(--line); border-radius:var(--radius); padding:26px 30px; background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.015)); color:#dfe7f5; }
      .quote cite { display:block; margin-top:10px; color:var(--muted); font-style:normal; font-size:14px; }
      .card-grid { display:grid; gap:22px; margin:0 0 76px; }
      .card-grid.top { grid-template-columns:1fr; }
      .card-grid.bottom { grid-template-columns:1fr 1fr; }
      .stage-card { border:1px solid var(--line); border-radius:var(--radius); padding:26px; background:linear-gradient(180deg, rgba(255,255,255,.026), rgba(255,255,255,.01)); }
      .stage-card[data-accent="blue"] { border-color:rgba(83,168,255,.35); }
      .stage-card[data-accent="amber"] { border-color:rgba(247,181,0,.35); }
      .stage-card[data-accent="violet"] { border-color:rgba(155,108,255,.35); }
      .stage-card[data-accent="green"] { border-color:rgba(24,214,163,.35); }
      .stage-card .num { color:var(--faint); letter-spacing:.18em; text-transform:uppercase; font:700 12px/1 Inter, sans-serif; }
      .stage-card h3 { margin:12px 0 8px; font-size:23px; letter-spacing:-.035em; }
      .stage-card p { margin:0 0 20px; color:var(--muted); }
      .viz { width:100%; min-height:260px; border:1px solid rgba(255,255,255,.07); border-radius:7px; background:#06080c; overflow:hidden; }
      .frameworks, .graphs, .subscribe { margin-bottom:76px; }
      .section-title { margin:0 0 20px; text-transform:uppercase; letter-spacing:.16em; color:#8792a6; font-size:15px; font-weight:680; }
      .framework-list { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
      .framework { min-height:68px; border:1px solid var(--line); border-radius:9px; padding:15px 17px; background:rgba(255,255,255,.018); }
      .framework:hover { border-color:#3b465a; background:rgba(255,255,255,.035); }
      .framework b { display:block; font-size:17px; letter-spacing:-.02em; }
      .framework span { display:block; margin-top:4px; color:var(--muted); font-size:14px; line-height:1.35; }
      .graph-list { display:grid; gap:26px; max-width:880px; }
      .group h3 { color:var(--faint); text-transform:uppercase; letter-spacing:.18em; font-size:12px; margin:0 0 10px; }
      .linkrow { display:grid; grid-template-columns:180px 1fr; gap:18px; padding:14px 0; border-bottom:1px solid rgba(255,255,255,.055); }
      .linkrow b { font-size:20px; letter-spacing:-.03em; }
      .linkrow span { color:var(--muted); }
      .subscribe { border:1px solid var(--line); border-radius:var(--radius); padding:28px; background:rgba(255,255,255,.025); }
      .subscribe h2 { margin:0 0 6px; letter-spacing:-.03em; }
      .subscribe p { margin:0 0 18px; color:var(--muted); }
      .email-form { display:grid; grid-template-columns:1fr auto; gap:14px; }
      .email-form input { min-height:48px; border-radius:9px; border:1px solid var(--line); padding:0 16px; background:#11141a; color:var(--ink); font:inherit; }
      .email-form button { min-height:48px; border:0; border-radius:9px; padding:0 24px; background:#f2f5fb; color:#05070b; font:750 15px Inter, sans-serif; }
      footer { border-top:1px solid rgba(255,255,255,.08); padding:32px 0 56px; color:var(--faint); font-size:14px; }
      footer .links { display:flex; gap:12px; margin-bottom:28px; }
      svg text { font-family: Inter, sans-serif; }

      /* The base blog pipeline appends legacy global CSS after page CSS. Keep this artifact self-contained. */
      body { margin:0 !important; background: radial-gradient(circle at 50% -12%, rgba(83,168,255,.14), transparent 34rem), linear-gradient(180deg, #07090f 0%, var(--bg) 42rem) !important; color:var(--ink) !important; font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important; }
      body :is(h1,h2,h3,p,a,b,strong,span,div,input,button) { font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important; }
      body :is(h1,h2,h3,p,a,b,strong,span,div) { font-style:normal !important; }
      header.topbar { display:block !important; flex-direction:initial !important; align-items:initial !important; position:sticky !important; top:0 !important; width:auto !important; max-width:none !important; margin:0 !important; padding:0 !important; background:rgba(5,7,11,.74) !important; text-align:initial !important; }
      header.topbar nav.nav { position:static !important; width:min(1040px, calc(100% - 40px)) !important; padding:0 !important; background:transparent !important; text-align:initial !important; font-weight:inherit !important; }
      header.topbar a { color:inherit !important; margin:0 !important; }
      main.wrap { display:block !important; border-top:0 !important; }
      main.wrap > section,
      main.wrap > aside,
      .hero,
      .hero-copy,
      .identity,
      .metric-grid,
      .split,
      .cta,
      .card-grid,
      .frameworks,
      .graphs,
      .subscribe,
      article.stage-card { width:100% !important; max-width:100% !important; margin-left:0 !important; margin-right:0 !important; min-width:0 !important; }
      .hero h2 { width:100% !important; max-width:100% !important; overflow-wrap:normal !important; font-style:normal !important; font-size:clamp(34px, 6.2vw, 72px) !important; line-height:.93 !important; }
      .lede { width:100% !important; max-width:780px !important; }
      .email-form { border:0 !important; padding:0 !important; margin:0 !important; }
      .email-form input { margin:0 !important; border:1px solid var(--line) !important; background:#11141a !important; color:var(--ink) !important; }
      .email-form button { margin:0 !important; background:#f2f5fb !important; color:#05070b !important; }
      footer > * { margin-left:auto !important; margin-right:auto !important; }
      .identity h1 { font-size:clamp(34px, 5vw, 54px) !important; line-height:.96 !important; }
      .wrap { max-width:none !important; }

      @media (max-width: 760px) {
        html, body { max-width:100% !important; overflow-x:hidden !important; }
        .wrap,
        header.topbar nav.nav { width:min(100% - 24px, 1040px) !important; }
        .nav { min-height:56px !important; align-items:center !important; padding:10px 0 !important; }
        .navlinks { display:none !important; }
        .brand { gap:10px !important; font-size:15px !important; }
        .mark { width:32px !important; height:32px !important; border-radius:8px !important; }
        .hero { padding:34px 0 26px !important; }
        .identity { align-items:center !important; gap:14px !important; margin-bottom:30px !important; }
        .portrait { width:58px !important; height:58px !important; flex:0 0 58px !important; }
        .identity h1 { font-size:34px !important; letter-spacing:-.055em !important; }
        .subtitle { font-size:14px !important; line-height:1.35 !important; margin-top:5px !important; }
        .eyebrow { font-size:11px !important; line-height:1.35 !important; letter-spacing:.13em !important; }
        .hero h2 { font-size:clamp(36px, 12.2vw, 48px) !important; line-height:.98 !important; letter-spacing:-.065em !important; text-wrap:balance !important; }
        .lede { font-size:17px !important; line-height:1.45 !important; margin-top:18px !important; }
        .metric-grid, .split, .card-grid.bottom, .framework-list, .email-form { grid-template-columns:1fr !important; }
        .metric-grid { gap:10px !important; margin:26px 0 30px !important; }
        .metric { padding:16px !important; text-align:left !important; }
        .metric b { font-size:24px !important; }
        .split { gap:26px !important; padding:26px 0 !important; }
        .chain, .roles { gap:8px !important; line-height:1.7 !important; }
        .cta { padding:28px 0 34px !important; }
        .buttons { display:grid !important; grid-template-columns:1fr !important; gap:10px !important; }
        .button { min-height:44px !important; display:flex !important; align-items:center !important; justify-content:center !important; padding:10px 14px !important; }
        .quote { margin:18px 0 40px !important; padding:20px !important; }
        .card-grid { gap:14px !important; margin-bottom:44px !important; }
        .stage-card { padding:18px !important; border-radius:12px !important; }
        .stage-card h3 { font-size:22px !important; line-height:1.15 !important; }
        .stage-card p { font-size:15px !important; line-height:1.45 !important; }
        .viz { min-height:190px !important; overflow-x:auto !important; overflow-y:hidden !important; -webkit-overflow-scrolling:touch !important; }
        .viz svg { min-width:620px !important; min-height:190px !important; display:block !important; }
        .card-grid.bottom .viz svg { min-width:420px !important; }
        .frameworks, .graphs, .subscribe { margin-bottom:48px !important; }
        .framework { min-height:auto !important; padding:15px !important; }
        .linkrow { grid-template-columns:1fr !important; gap:4px !important; padding:13px 0 !important; }
        .linkrow b { font-size:18px !important; }
        .subscribe { padding:20px !important; }
        .email-form { gap:10px !important; }
        .email-form input,
        .email-form button { width:100% !important; min-height:48px !important; }
        footer { padding:28px 0 44px !important; }
        footer .links { display:grid !important; grid-template-columns:1fr !important; gap:10px !important; }
      }

      @media (max-width: 420px) {
        .wrap,
        header.topbar nav.nav { width:calc(100% - 20px) !important; }
        .hero h2 { font-size:clamp(33px, 11.4vw, 42px) !important; }
        .identity h1 { font-size:30px !important; }
        .subtitle { font-size:13px !important; }
        .stage-card { padding:16px !important; }
        .viz { margin-inline:-6px !important; border-inline:0 !important; border-radius:8px !important; }
      }
    </style>
  </head>
  <body>
    {{ content | safe }}
  </body>
</html>
